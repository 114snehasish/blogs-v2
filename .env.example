# GitHub repository that contains the blog markdown files
VITE_CONTENT_REPO_OWNER=your-github-username
VITE_CONTENT_REPO_NAME=blog-content
VITE_CONTENT_REPO_BRANCH=main

# Subdirectory within the repo where posts live (leave empty for root)
VITE_CONTENT_DIR=posts

# Optional: GitHub personal access token for higher API rate limits
# VITE_GITHUB_TOKEN=ghp_...
